# Market and Shop — Vite + React. Use VITE_ prefix (not NEXT_PUBLIC_).
# Copy to .env.local for local development. Production values go in Vercel.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

VITE_API_URL=http://localhost:3001
VITE_AUTH_MODE=hybrid

# Auth0 (optional — Vercel Auth0 integration auto-provisions AUTH0_* at build time)
VITE_AUTH0_ENABLED=true
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id
# VITE_AUTH0_CALLBACK_PATH=/api/auth/callback
# VITE_APP_URL=https://your-app.vercel.app

# Sentry (optional — Client DSN from sentry.io project settings)
VITE_SENTRY_DSN=

# Upstash Redis (optional — KV_REST_API_* from Vercel Upstash integration, used by backend)